rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: any logged-in user can read profiles; only owner can write their own doc
    match /users/{userId} {
      allow read: if request.auth != null || userId.matches('demo_user_.*');
      allow create: if (request.auth != null && request.auth.uid == userId) || userId.matches('demo_user_.*');
      allow update: if (request.auth != null && request.auth.uid == userId) || userId.matches('demo_user_.*');
      allow delete: if false;
    }

    // Likes/swipes: any auth user can read (for mutual-like check);
    // only the swiper writes to their own likes doc
    match /likes/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Matches and their messages: any auth user can read/write
    match /matches/{matchId} {
      allow read, write: if request.auth != null;

      match /messageBatches/{batchId} {
        allow read, write: if request.auth != null;
      }
    }

    // Received likes: only the recipient can read their own doc;
    // any authenticated user can write (the swiper writes to the recipient's doc)
    match /received_likes/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

    // Received super likes
    match /received_super_likes/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

  }
}
